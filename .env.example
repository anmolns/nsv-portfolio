# --- Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets) ---
# Portfolio access gate — Meta WhatsApp Cloud API (official)
#
# OTP_HASH_SECRET=long-random-string
#
# Production (Meta WhatsApp Cloud API):
# WHATSAPP_ACCESS_TOKEN=          # Permanent token from Meta Developer / Business
# WHATSAPP_PHONE_NUMBER_ID=       # From WhatsApp → API Setup
# WHATSAPP_OTP_TEMPLATE=portfolio_access_otp
# WHATSAPP_TEMPLATE_LANGUAGE=en   # or en_US — must match approved template
# WHATSAPP_OTP_TEMPLATE_TYPE=authentication   # authentication | utility
# WHATSAPP_OTP_COPY_BUTTON=true   # false if auth template has no copy-code button
# WHATSAPP_GRAPH_API_VERSION=v21.0
#
# Local testing only (logs OTP to edge function logs, does not send WhatsApp):
# WHATSAPP_DEV_MODE=true
