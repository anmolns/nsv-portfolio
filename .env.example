# =============================================================================
# NS Ventures Portfolio — environment variables
# Copy to `.env.local` for local dev (never commit `.env.local`)
# =============================================================================

# -----------------------------------------------------------------------------
# 1) PUBLIC SITE (Vite) — required for npm run dev / Vercel build
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Production (Vercel) — public site env vars
# VITE_SUPABASE_URL=...
# VITE_SUPABASE_ANON_KEY=...

# WhatsApp relay on Vercel uses /api/authyo/send-otp (serverless) — set these on Vercel, NOT with VITE_ prefix:
# OTP_HASH_SECRET=same-as-supabase-edge-secret
# AUTHYO_CLIENT_ID=from-authyo-dashboard
# AUTHYO_CLIENT_SECRET=from-authyo-dashboard
# AUTHYO_AUTHORIZED_ENDPOINT=https://your-site.vercel.app

# Optional — only if relay runs on a separate host (Railway) instead of Vercel serverless:
# VITE_AUTHYO_RELAY_URL=https://your-import-server.example.com/api/authyo/send-otp
# VITE_BULK_IMPORT_API_URL=https://your-import-server.example.com

# -----------------------------------------------------------------------------
# 2) LOCAL SCRIPTS & BULK IMPORT SERVER (.env.local)
#    Used by: npm run dev:import, delete:vr-tours, delete:videos
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Must match Supabase Edge secret OTP_HASH_SECRET (relay verifies dispatch tokens)
OTP_HASH_SECRET=change-me-to-a-long-random-string

# Authyo — relay server calls API (browser → :3001 → Authyo), NOT Supabase edge
AUTHYO_CLIENT_ID=your-client-id
AUTHYO_CLIENT_SECRET=your-client-secret
AUTHYO_AUTHORIZED_ENDPOINT=http://localhost:5173

# Optional — bulk import server port (default 3001)
# IMPORT_PORT=3001

# =============================================================================
# 3) SUPABASE EDGE FUNCTION SECRETS
#    Set in: Supabase Dashboard → Edge Functions → Secrets
#    (NOT in Vercel — server-side only)
# =============================================================================

# --- OTP & session (required) ---
# Random string, 32+ characters. Used to hash OTPs and sign 30-day JWTs.
OTP_HASH_SECRET=change-me-to-a-long-random-string

# Optional — separate JWT signing secret (defaults to OTP_HASH_SECRET)
# ACCESS_TOKEN_SECRET=

# --- Email OTP (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=NS Ventures <noreply@nsventures.in>

# true = log OTP to edge logs, do not send email (local testing)
RESEND_DEV_MODE=false

# --- WhatsApp OTP (Authyo) — relay on bulk-import server; edge only issues dispatch token ---
# AUTHYO_* in Supabase secrets are optional if using relay only (keep OTP_HASH_SECRET)
AUTHYO_CLIENT_ID=ee72e07075cc469a9a66fcc5e758afbf
AUTHYO_CLIENT_SECRET=paste-from-authyo-dashboard
# AUTHYO_APP_ID=18e8a35427984ee1a47d2e11b6323e41

# Must match Authyo → Application → Authorized endpoint EXACTLY (no trailing slash).
AUTHYO_AUTHORIZED_ENDPOINT=http://localhost:5173

# Comma-separated — add your Supabase project URL (server-side API calls use this).
# Example: AUTHYO_EXTRA_ORIGINS=https://YOUR_PROJECT_REF.supabase.co,http://localhost:5173
AUTHYO_EXTRA_ORIGINS=https://ozkhlknqrzhgsvrwjhtj.supabase.co,http://localhost:5173

AUTHYO_APP_ID=18e8a35427984ee1a47d2e11b6323e41

# true = log WhatsApp OTP, skip Authyo API (local testing)
AUTHYO_DEV_MODE=false

# --- Callback form (navbar "Get a callback") ---
CALLBACK_NOTIFY_EMAIL=prateek@nsventures.in

# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected on edge deploy.

# =============================================================================
# QUICK REFERENCE — where each value lives
# =============================================================================
#
# | Variable                    | Where to set                          |
# |-----------------------------|---------------------------------------|
# | VITE_SUPABASE_*             | .env.local + Vercel env               |
# | VITE_BULK_IMPORT_API_URL    | Vercel env (production bulk upload)   |
# | SUPABASE_SERVICE_ROLE_KEY   | .env.local only (never Vite/public)   |
# | VITE_AUTHYO_RELAY_URL       | Vercel env (production WhatsApp relay) |
# | OTP_HASH_SECRET             | .env.local + Supabase secrets (must match) |
# | AUTHYO_* (relay)            | .env.local only (import server)        |
# | OTP_HASH_SECRET, Resend,    | Supabase Edge Function secrets only   |
# | CALLBACK_*                  |                                       |
#
# When you get your live site URL:
#   1. Set AUTHYO_ORIGIN to that URL in Supabase secrets
#   2. Add the same URL in Authyo → Application → Authorized endpoint
#   3. For local dev, use http://localhost:5173 in both places
