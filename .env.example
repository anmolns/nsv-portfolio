# --- Public site (Vite) — required ---
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# --- Production bulk import (optional) ---
# When the site is deployed (Vercel etc.), point admin bulk upload at your import server:
# VITE_BULK_IMPORT_API_URL=https://import.yoursite.com

# --- Local bulk import server (.env.local) — not committed ---
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# PORT=3001

# --- Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets) ---
# Portfolio access gate — Resend email OTP
#
# OTP_HASH_SECRET=long-random-string
#
# Production (Resend):
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=NS Ventures <noreply@nsventures.in>
#
# Local testing only (logs OTP to edge function logs, does not send email):
# RESEND_DEV_MODE=true
